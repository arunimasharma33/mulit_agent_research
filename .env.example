# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================================================
# LLM Configuration
# ============================================================================

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Mistral AI API Key (https://console.mistral.ai/api-keys/)
MISTRAL_API_KEY=your_mistral_api_key_here

# ============================================================================
# Search Configuration
# ============================================================================

# Tavily Search API Key (https://tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================================
# Database Configuration
# ============================================================================

# SQLite database URL (relative path from project root)
DATABASE_URL=sqlite:///./data/research.db

# For PostgreSQL (example):
# DATABASE_URL=postgresql://user:password@localhost/research_db

# ============================================================================
# Security & Authentication
# ============================================================================

# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=your_secret_key_change_this_in_production

# JWT Algorithm
JWT_ALGORITHM=HS256

# JWT Token Expiration (in hours)
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Server Configuration
# ============================================================================

# Backend API Host
BACKEND_HOST=127.0.0.1

# Backend API Port
BACKEND_PORT=8765

# Frontend Development Port
FRONTEND_PORT=5173

# ============================================================================
# Logging Configuration (Optional)
# ============================================================================

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# Feature Flags (Optional)
# ============================================================================

# Enable debug mode (set to False in production)
DEBUG=True

# Enable CORS for development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ============================================================================
# Additional LLM Parameters (Optional)
# ============================================================================

# Temperature for LLM responses (0.0 to 2.0, higher = more creative)
LLM_TEMPERATURE=0.3

# Max tokens per response
LLM_MAX_TOKENS=2000
